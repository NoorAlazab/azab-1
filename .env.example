# Environment Configuration
# Copy this file to .env.local and fill in your values

# Atlassian OAuth Configuration
ATLASSIAN_CLIENT_ID=your_atlassian_client_id_here
ATLASSIAN_CLIENT_SECRET=your_atlassian_client_secret_here
ATLASSIAN_REDIRECT_URI=http://localhost:3000/api/auth/atlassian/callback

# App Configuration
APP_URL=http://localhost:3000
SESSION_SECRET=your_session_secret_here_minimum_32_characters_long

# Environment
NODE_ENV=development

# Rate limiting (optional)
# When both vars are set, distributed sliding-window rate limiting is
# enabled via Upstash Redis. Without them, the app falls back to an
# in-process token bucket — fine for local dev / single-instance, but
# NOT correct under horizontal scaling.
# UPSTASH_REDIS_REST_URL=https://your-region-xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here