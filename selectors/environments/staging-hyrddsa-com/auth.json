{
  "page": "auth",
  "description": "Login page (auth path) - user authentication form elements for staging.hyrddsa.com",
  "version": "1.0",
  "lastUpdated": "2025-10-29T07:20:00Z",
  "elements": {
    "emailField": {
      "key": "emailField",
      "primary": "input[name='email']",
      "fallbacks": [
        "input[type='email']",
        "input[id='email']",
        "input[placeholder*='email' i]",
        "input[aria-label*='email' i]"
      ],
      "metadata": {
        "type": "input",
        "name": "email",
        "placeholder": "Email address",
        "description": "Email/username input field"
      }
    },
    "passwordField": {
      "key": "passwordField",
      "primary": "input[name='password']",
      "fallbacks": [
        "input[type='password']",
        "input[id='password']",
        "input[placeholder*='password' i]"
      ],
      "metadata": {
        "type": "input",
        "name": "password",
        "description": "Password input field"
      }
    },
    "loginButton": {
      "key": "loginButton",
      "primary": "button[type='submit']",
      "fallbacks": [
        "button:has-text('Sign In')",
        "button:has-text('Login')",
        "button:has-text('Log in')",
        "form button[type='button']:has-text('Sign')"
      ],
      "metadata": {
        "type": "button",
        "text": "Sign In",
        "description": "Submit button to login"
      },
      "context": {
        "insideContainer": "form",
        "nearElement": "input[type='password']"
      }
    },
    "rememberMeCheckbox": {
      "key": "rememberMeCheckbox",
      "primary": "input[type='checkbox'][name='remember']",
      "fallbacks": [
        "input[type='checkbox'][id*='remember' i]",
        "label:has-text('Remember') input[type='checkbox']"
      ],
      "metadata": {
        "type": "checkbox",
        "name": "remember",
        "label": "Remember me",
        "description": "Remember me checkbox"
      }
    },
    "forgotPasswordLink": {
      "key": "forgotPasswordLink",
      "primary": "a[href*='forgot']",
      "fallbacks": [
        "a:has-text('Forgot password')",
        "a:has-text('Reset password')",
        "button:has-text('Forgot password')"
      ],
      "metadata": {
        "type": "link",
        "text": "Forgot password?",
        "description": "Link to password reset flow"
      }
    },
    "signupLink": {
      "key": "signupLink",
      "primary": "a[href*='signup']",
      "fallbacks": [
        "a[href*='register']",
        "a:has-text('Sign up')",
        "a:has-text('Create account')",
        "a:has-text('Register')"
      ],
      "metadata": {
        "type": "link",
        "text": "Sign up",
        "description": "Link to registration/signup page"
      }
    },
    "errorMessage": {
      "key": "errorMessage",
      "primary": "[role='alert']",
      "fallbacks": [
        ".error-message",
        ".alert-error",
        ".text-red-600",
        "p.error",
        "[data-testid='error-message']"
      ],
      "metadata": {
        "type": "text",
        "description": "Error message display (e.g., invalid credentials)",
        "notes": "This element appears only when there's an error"
      }
    },
    "successMessage": {
      "key": "successMessage",
      "primary": "[role='status'][data-type='success']",
      "fallbacks": [
        ".success-message",
        ".alert-success",
        ".text-green-600",
        "[data-testid='success-message']"
      ],
      "metadata": {
        "type": "text",
        "description": "Success message display",
        "notes": "Appears after successful login or other positive actions"
      }
    },
    "loginForm": {
      "key": "loginForm",
      "primary": "form[action*='login']",
      "fallbacks": [
        "form[name='login']",
        "form:has(input[type='password'])",
        ".login-form"
      ],
      "metadata": {
        "type": "form",
        "description": "Main login form container"
      }
    },
    "showPasswordToggle": {
      "key": "showPasswordToggle",
      "primary": "button[aria-label*='show password' i]",
      "fallbacks": [
        "button[aria-label*='toggle password' i]",
        "button.password-toggle",
        "button:has(svg.eye-icon)"
      ],
      "metadata": {
        "type": "button",
        "label": "Show password",
        "description": "Toggle to show/hide password text"
      },
      "context": {
        "nearElement": "input[type='password']"
      }
    }
  }
}
